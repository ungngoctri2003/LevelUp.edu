# Copy to .env.local and fill in values from Supabase Project Settings → API.
# Vite only exposes variables prefixed with VITE_.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-or-anon-key

# Express API (`npm run server`) — CRUD /admin dùng service role (chỉ trên server, không commit).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
